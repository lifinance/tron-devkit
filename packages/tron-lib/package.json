{
  "name": "@lifi/tron-devkit",
  "version": "1.0.1-alpha.1",
  "description": "Shared Tron development library for LI.FI contract repos — deployment, address helpers, energy estimation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./safe": {
      "types": "./dist/safe/index.d.ts",
      "import": "./dist/safe/index.js"
    }
  },
  "files": [
    "dist",
    "postinstall-tronweb-fix.mjs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "bunx --bun tsc",
    "postinstall": "node postinstall-tronweb-fix.mjs"
  },
  "dependencies": {
    "consola": "^3.2.3",
    "tronweb": "^6.0.3",
    "viem": "^2.22.16"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.7.0"
  }
}
